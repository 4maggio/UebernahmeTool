# ───────────────────────────────
# Database
# ───────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/unternehmensbewertung

# ───────────────────────────────
# Authentication (JWT)
# ───────────────────────────────
JWT_SECRET=change_me_to_a_minimum_64_char_random_secret_string_here_please
JWT_EXPIRES_IN=8h

# ───────────────────────────────
# OpenAI
# ───────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ───────────────────────────────
# Server
# ───────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ───────────────────────────────
# Admin seed account
# Generate hash: node -e "require('bcrypt').hash('yourpw',12).then(console.log)"
# ───────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# ───────────────────────────────
# Scraper
# ───────────────────────────────
SCRAPER_ENABLED=true
SCRAPER_CRON=0 3 * * 1

# ───────────────────────────────
# Rate limiting
# ───────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
